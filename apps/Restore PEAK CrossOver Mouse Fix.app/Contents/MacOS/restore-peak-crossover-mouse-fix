#!/bin/bash
set -euo pipefail

APP_CONTENTS_DIR="$(cd "$(dirname "$0")/.." && pwd)"
APP_BUNDLE_DIR="$(cd "$APP_CONTENTS_DIR/.." && pwd)"
CONTAINER_DIR="$(cd "$APP_BUNDLE_DIR/.." && pwd)"
SUPPORT_ROOT="$CONTAINER_DIR/Support"
REPO_ROOT="$(cd "$APP_CONTENTS_DIR/../../.." && pwd)"

if [[ -f "$SUPPORT_ROOT/scripts/restore-crossover-pointer-fix.sh" ]]; then
  RUN_ROOT="$SUPPORT_ROOT"
else
  RUN_ROOT="$REPO_ROOT"
fi

SCRIPT_PATH="$RUN_ROOT/scripts/restore-crossover-pointer-fix.sh"

/usr/bin/osascript <<OSA
tell application "Terminal"
  activate
  do script "bash " & quoted form of "$SCRIPT_PATH"
end tell
OSA
